<?xml version="1.0" encoding="utf-8"?>
<!--
    Sticky bottom bar dùng cho MenuActivity.
    Activity:
    - set GONE nếu cart rỗng (totalQuantity = 0)
    - set tv_count = "X món đã chọn"
    - set tv_total = CurrencyUtils.formatVnd(totalAmount)
    - btn_view_order: click → mở OrderActivity
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card"
    android:padding="@dimen/spacing_lg"
    android:elevation="8dp"
    android:layout_margin="@dimen/spacing_md">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_cart_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Cafe.Caption"
            tools:text="3 món đã chọn" />

        <TextView
            android:id="@+id/tv_cart_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Cafe.Subtitle"
            android:textColor="@color/text_primary"
            android:layout_marginTop="@dimen/spacing_xs"
            tools:text="119.000đ" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_view_order"
        style="@style/Widget.Cafe.Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/height_button"
        android:text="@string/btn_view_order" />
</LinearLayout>
