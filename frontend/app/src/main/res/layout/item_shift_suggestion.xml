<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_lg"
    android:layout_marginVertical="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/spacing_md"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <TextView
            android:id="@+id/tv_shift_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên ca"
            android:textAppearance="@style/TextAppearance.Cafe.Subtitle"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_shift_date_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="01/01/2024 08:00–12:00"
            android:textAppearance="@style/TextAppearance.Cafe.Caption"
            android:textColor="@color/text_soft" />

        <TextView
            android:id="@+id/tv_suggested_staff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Nguyễn Văn A, Trần Thị B"
            android:textAppearance="@style/TextAppearance.Cafe.Body" />

        <TextView
            android:id="@+id/tv_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="✅ Đủ người"
            android:textAppearance="@style/TextAppearance.Cafe.Caption"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
