<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="@dimen/spacing_md"
    android:layout_marginBottom="@dimen/spacing_md"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_shift_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="@style/TextAppearance.Cafe.Subtitle"
            tools:text="Ca Sáng" />

        <TextView
            android:id="@+id/tv_shift_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:paddingVertical="@dimen/spacing_xs"
            android:background="@drawable/bg_badge_success"
            android:textAppearance="@style/TextAppearance.Cafe.Caption"
            android:textColor="@color/success"
            tools:text="CLOSED" />
    </LinearLayout>

    <!-- Time Row -->
    <TextView
        android:id="@+id/tv_shift_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Cafe.Caption"
        android:textColor="@color/text_soft"
        android:layout_marginTop="@dimen/spacing_xs"
        tools:text="07:00 - 12:00" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"
        android:layout_marginVertical="@dimen/spacing_md" />

    <!-- Info Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Doanh thu: "
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:textColor="@color/text_soft" />

        <TextView
            android:id="@+id/tv_shift_revenue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="@style/TextAppearance.Cafe.BodyBold"
            android:textColor="@color/accent"
            tools:text="1,200,000đ" />

        <TextView
            android:id="@+id/tv_shift_orders"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Cafe.Caption"
            tools:text="12 đơn hàng" />
    </LinearLayout>
</LinearLayout>
