<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_login_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="@dimen/spacing_xl">

        <!-- Spacer to push content down -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Logo / Brand Header Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="96dp"
            android:layout_height="96dp"
            app:cardCornerRadius="48dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/border"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="@dimen/spacing_md">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_coffee"
                android:padding="24dp"
                android:layout_gravity="center"
                app:tint="@color/accent"
                android:contentDescription="@null" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textAppearance="@style/TextAppearance.Cafe.Display"
            android:layout_marginTop="@dimen/spacing_sm" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng nhập để bắt đầu"
            android:textAppearance="@style/TextAppearance.Cafe.Caption"
            android:textColor="@color/text_soft"
            android:layout_marginTop="@dimen/spacing_xs"
            android:layout_marginBottom="32dp" />

        <!-- Main Login Card Form -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_sm"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/border_soft"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- 1. Credentials Container -->
                <LinearLayout
                    android:id="@+id/layout_credentials"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Username Input Container -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_username"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Tên đăng nhập"
                        app:startIconDrawable="@drawable/ic_user"
                        app:startIconTint="@color/text_soft"
                        app:boxStrokeColor="@color/accent"
                        app:hintTextColor="@color/accent"
                        app:errorEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_username"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:autofillHints="username" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password Input Container -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_password"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Mật khẩu"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/text_soft"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/text_soft"
                        app:boxStrokeColor="@color/accent"
                        app:hintTextColor="@color/accent"
                        app:errorEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:autofillHints="password" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Login Button -->
                    <Button
                        android:id="@+id/btn_login"
                        style="@style/Widget.Cafe.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Đăng nhập"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- 2. OTP Container -->
                <LinearLayout
                    android:id="@+id/layout_otp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_otp_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mã OTP đã được gửi đến email của bạn. Vui lòng nhập 6 chữ số để xác nhận."
                        android:textColor="@color/text_soft"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"
                        android:textAlignment="center" />

                    <!-- OTP Input Container -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_otp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Mã xác thực OTP"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/text_soft"
                        app:boxStrokeColor="@color/accent"
                        app:hintTextColor="@color/accent"
                        app:errorEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_otp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="6"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:letterSpacing="0.2" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Resend text button -->
                    <TextView
                        android:id="@+id/btn_resend_otp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gửi lại mã (60s)"
                        android:textColor="@color/accent"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_gravity="end"
                        android:layout_marginBottom="16dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Confirm Button -->
                    <Button
                        android:id="@+id/btn_confirm_otp"
                        style="@style/Widget.Cafe.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Xác nhận mã OTP"
                        android:layout_marginBottom="8dp" />

                    <!-- Back to Login Button -->
                    <Button
                        android:id="@+id/btn_back_to_login"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Quay lại đăng nhập"
                        android:textColor="@color/text_soft" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Spacer at bottom for centering -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1.5" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
