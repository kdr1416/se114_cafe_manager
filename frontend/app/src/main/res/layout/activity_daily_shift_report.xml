<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Top Bar -->
    <include
        android:id="@+id/top_bar"
        layout="@layout/component_top_bar" />

    <!-- Date Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_sm">

        <ImageButton
            android:id="@+id/btn_prev_date"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_chevron_left"
            android:background="@drawable/bg_icon_button"
            android:scaleType="centerInside"
            android:contentDescription="Previous Day" />

        <TextView
            android:id="@+id/tv_date_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textAppearance="@style/TextAppearance.Cafe.BodyBold"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            tools:text="Thứ Sáu, 26/06/2026" />

        <ImageButton
            android:id="@+id/btn_next_date"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_chevron_right"
            android:background="@drawable/bg_icon_button"
            android:scaleType="centerInside"
            android:contentDescription="Next Day" />
    </LinearLayout>

    <!-- Main Content Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <!-- Daily Summary Card -->
                <LinearLayout
                    android:id="@+id/card_daily_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="@dimen/spacing_lg"
                    android:layout_marginBottom="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng quan trong ngày"
                        android:textAppearance="@style/TextAppearance.Cafe.SectionLabel"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Doanh thu ngày"
                        android:textAppearance="@style/TextAppearance.Cafe.Caption"
                        android:textColor="@color/text_soft" />

                    <TextView
                        android:id="@+id/tv_daily_revenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Cafe.Title"
                        android:textColor="@color/accent"
                        android:layout_marginBottom="@dimen/spacing_md"
                        tools:text="15,400,000đ" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Grid Stats -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Số đơn hàng"
                                android:textAppearance="@style/TextAppearance.Cafe.Caption"
                                android:textColor="@color/text_soft" />

                            <TextView
                                android:id="@+id/tv_daily_orders"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Cafe.BodyBold"
                                tools:text="45 đơn" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Số giao dịch"
                                android:textAppearance="@style/TextAppearance.Cafe.Caption"
                                android:textColor="@color/text_soft" />

                            <TextView
                                android:id="@+id/tv_daily_payments"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Cafe.BodyBold"
                                tools:text="42 lượt" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Két mở đầu"
                                android:textAppearance="@style/TextAppearance.Cafe.Caption"
                                android:textColor="@color/text_soft" />

                            <TextView
                                android:id="@+id/tv_daily_opening_cash"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Cafe.BodyBold"
                                tools:text="2,000,000đ" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tiền dự kiến"
                                android:textAppearance="@style/TextAppearance.Cafe.Caption"
                                android:textColor="@color/text_soft" />

                            <TextView
                                android:id="@+id/tv_daily_expected_cash"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Cafe.BodyBold"
                                tools:text="12,500,000đ" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Section: Shift reports list -->
                <TextView
                    android:id="@+id/tv_shifts_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Báo cáo từng ca"
                    android:textAppearance="@style/TextAppearance.Cafe.SectionLabel"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_shifts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_daily_shift_summary" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layout_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/spacing_xl"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_eye"
                android:contentDescription="Empty icon"
                android:alpha="0.4" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Không có ca làm việc nào"
                android:textAppearance="@style/TextAppearance.Cafe.BodyBold"
                android:textColor="@color/text_soft"
                android:layout_marginTop="@dimen/spacing_md" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Không có dữ liệu ca làm trong ngày được chọn."
                android:textAppearance="@style/TextAppearance.Cafe.Caption"
                android:textColor="@color/text_soft"
                android:layout_marginTop="@dimen/spacing_xs"
                android:gravity="center" />
        </LinearLayout>

        <!-- Loading View -->
        <ProgressBar
            android:id="@+id/progress_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
