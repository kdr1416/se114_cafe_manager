<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <include
        android:id="@+id/top_bar"
        layout="@layout/component_top_bar" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chat_messages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingVertical="@dimen/spacing_md" />

        <include
            android:id="@+id/empty_state"
            layout="@layout/component_empty_state"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- Bottom Send panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_md"
        android:elevation="4dp">

        <EditText
            android:id="@+id/et_message_input"
            android:layout_width="0dp"
            android:layout_height="@dimen/height_input"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="@dimen/spacing_md"
            android:inputType="textShortMessage"
            android:imeOptions="actionSend"
            style="@style/TextAppearance.Cafe.Body"
            android:hint="Nhập tin nhắn..."
            android:layout_marginEnd="@dimen/spacing_sm" />

        <Button
            android:id="@+id/btn_message_send"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/height_button"
            style="@style/Widget.Cafe.Button.Primary"
            android:text="Gửi" />
    </LinearLayout>
</LinearLayout>
