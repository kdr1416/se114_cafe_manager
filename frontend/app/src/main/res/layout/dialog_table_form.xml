<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tên bàn"
        android:textAppearance="@style/TextAppearance.Cafe.SectionLabel" />

    <EditText
        android:id="@+id/et_table_name"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_input"
        android:background="@drawable/bg_input"
        android:paddingHorizontal="@dimen/spacing_md"
        android:inputType="text"
        android:singleLine="true"
        android:hint="VD: B11"
        android:layout_marginTop="@dimen/spacing_sm"
        android:autofillHints="off" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sức chứa (người)"
        android:textAppearance="@style/TextAppearance.Cafe.SectionLabel"
        android:layout_marginTop="@dimen/spacing_md" />

    <EditText
        android:id="@+id/et_capacity"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_input"
        android:background="@drawable/bg_input"
        android:paddingHorizontal="@dimen/spacing_md"
        android:inputType="number"
        android:singleLine="true"
        android:hint="VD: 4"
        android:layout_marginTop="@dimen/spacing_sm"
        android:autofillHints="off" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Khu vực"
        android:textAppearance="@style/TextAppearance.Cafe.SectionLabel"
        android:layout_marginTop="@dimen/spacing_md" />

    <Spinner
        android:id="@+id/spinner_area"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_input"
        android:background="@drawable/bg_input"
        android:layout_marginTop="@dimen/spacing_sm" />
</LinearLayout>
