<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <include
        android:id="@+id/top_bar"
        layout="@layout/component_top_bar" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Card layout for inputs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <!-- Title input -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Cafe.SectionLabel"
                    android:textColor="@color/text_soft"
                    android:text="Tiêu đề bài viết"
                    android:layout_marginBottom="@dimen/spacing_xs" />

                <EditText
                    android:id="@+id/et_form_title"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/height_input"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:inputType="text"
                    android:maxLines="1"
                    style="@style/TextAppearance.Cafe.Body"
                    android:hint="Nhập tiêu đề (tối đa 100 ký tự)" />

                <!-- Content input -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Cafe.SectionLabel"
                    android:textColor="@color/text_soft"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Nội dung thông báo"
                    android:layout_marginBottom="@dimen/spacing_xs" />

                <EditText
                    android:id="@+id/et_form_content"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:background="@drawable/bg_input"
                    android:gravity="top"
                    android:padding="@dimen/spacing_md"
                    android:inputType="textMultiLine"
                    style="@style/TextAppearance.Cafe.Body"
                    android:hint="Nhập nội dung thông báo..." />

                <!-- Spinner for Type -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Cafe.SectionLabel"
                    android:textColor="@color/text_soft"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Phân loại (Type)"
                    android:layout_marginBottom="@dimen/spacing_xs" />

                <Spinner
                    android:id="@+id/spinner_form_type"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/height_input"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="@dimen/spacing_md" />

                <!-- Spinner for Priority -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Cafe.SectionLabel"
                    android:textColor="@color/text_soft"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Độ ưu tiên (Priority)"
                    android:layout_marginBottom="@dimen/spacing_xs" />

                <Spinner
                    android:id="@+id/spinner_form_priority"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/height_input"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="@dimen/spacing_md" />

                <!-- Target selection -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Cafe.SectionLabel"
                    android:textColor="@color/text_soft"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Đối tượng xem (Target)"
                    android:layout_marginBottom="@dimen/spacing_xs" />

                <Spinner
                    android:id="@+id/spinner_form_target_type"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/height_input"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="@dimen/spacing_md" />

                <!-- Target Role Selection Container -->
                <LinearLayout
                    android:id="@+id/layout_target_role"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.Cafe.SectionLabel"
                        android:textColor="@color/text_soft"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="Chọn vai trò nhân viên"
                        android:layout_marginBottom="@dimen/spacing_xs" />

                    <Spinner
                        android:id="@+id/spinner_form_target_role"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/height_input"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="@dimen/spacing_md" />
                </LinearLayout>

                <!-- Target Shift Selection Container -->
                <LinearLayout
                    android:id="@+id/layout_target_shift"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.Cafe.SectionLabel"
                        android:textColor="@color/text_soft"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="Chọn ca làm việc"
                        android:layout_marginBottom="@dimen/spacing_xs" />

                    <Spinner
                        android:id="@+id/spinner_form_target_shift"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/height_input"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="@dimen/spacing_md" />
                </LinearLayout>

                <!-- Switch/Checkbox for Pinning -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:paddingVertical="@dimen/spacing_sm">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        style="@style/TextAppearance.Cafe.BodyBold"
                        android:text="Ghim bài viết lên đầu" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_form_pinned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

            </LinearLayout>

            <!-- Save action button -->
            <Button
                android:id="@+id/btn_form_save"
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_button"
                android:layout_marginTop="@dimen/spacing_xl"
                style="@style/Widget.Cafe.Button.Primary"
                android:text="Đăng bài viết" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
