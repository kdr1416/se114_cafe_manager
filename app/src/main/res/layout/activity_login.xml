<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_primary"
    android:padding="@dimen/spacing_xl">

    <!-- Logo / brand -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_coffee"
        android:background="@drawable/bg_media"
        android:padding="@dimen/spacing_lg"
        android:contentDescription="@null"
        app:tint="@color/accent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textAppearance="@style/TextAppearance.Cafe.Display"
        android:layout_marginTop="@dimen/spacing_md" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đăng nhập để bắt đầu"
        android:textAppearance="@style/TextAppearance.Cafe.Caption"
        android:layout_marginTop="@dimen/spacing_xs"
        android:layout_marginBottom="@dimen/spacing_xl" />

    <!-- Username input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên đăng nhập"
        android:textAppearance="@style/TextAppearance.Cafe.SectionLabel" />

    <EditText
        android:id="@+id/et_username"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_input"
        android:background="@drawable/bg_input"
        android:paddingHorizontal="@dimen/spacing_md"
        android:hint="Vd: staff hoặc admin"
        android:inputType="text"
        android:singleLine="true"
        android:autofillHints="username"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginBottom="@dimen/spacing_md" />

    <!-- Password input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mật khẩu"
        android:textAppearance="@style/TextAppearance.Cafe.SectionLabel" />

    <EditText
        android:id="@+id/et_password"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_input"
        android:background="@drawable/bg_input"
        android:paddingHorizontal="@dimen/spacing_md"
        android:hint="Mật khẩu"
        android:inputType="textPassword"
        android:singleLine="true"
        android:autofillHints="password"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <Button
        android:id="@+id/btn_login"
        style="@style/Widget.Cafe.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_button"
        android:text="Đăng nhập" />

    <!-- Hint demo accounts -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tài khoản thử: staff/123456 — manager/manager123 — admin/admin123"
        android:textAppearance="@style/TextAppearance.Cafe.Caption"
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_xl" />
</LinearLayout>
