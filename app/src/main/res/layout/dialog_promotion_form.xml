<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mã giảm giá"
        android:textAppearance="@style/TextAppearance.Cafe.SectionLabel" />

    <EditText
        android:id="@+id/et_code"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_input"
        android:background="@drawable/bg_input"
        android:paddingHorizontal="@dimen/spacing_md"
        android:inputType="textCapCharacters"
        android:singleLine="true"
        android:hint="VD: GIAM20K"
        android:layout_marginTop="@dimen/spacing_sm"
        android:autofillHints="off" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loại giảm giá"
        android:textAppearance="@style/TextAppearance.Cafe.SectionLabel"
        android:layout_marginTop="@dimen/spacing_md" />

    <Spinner
        android:id="@+id/spinner_type"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_input"
        android:background="@drawable/bg_input"
        android:layout_marginTop="@dimen/spacing_sm" />

    <TextView
        android:id="@+id/label_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Giá trị (VND)"
        android:textAppearance="@style/TextAppearance.Cafe.SectionLabel"
        android:layout_marginTop="@dimen/spacing_md" />

    <EditText
        android:id="@+id/et_value"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_input"
        android:background="@drawable/bg_input"
        android:paddingHorizontal="@dimen/spacing_md"
        android:inputType="numberDecimal"
        android:singleLine="true"
        android:hint="VD: 10000"
        android:layout_marginTop="@dimen/spacing_sm"
        android:autofillHints="off" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ngày hết hạn (để trống = vĩnh viễn)"
        android:textAppearance="@style/TextAppearance.Cafe.SectionLabel"
        android:layout_marginTop="@dimen/spacing_md" />

    <EditText
        android:id="@+id/et_expires"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_input"
        android:background="@drawable/bg_input"
        android:paddingHorizontal="@dimen/spacing_md"
        android:focusable="false"
        android:clickable="true"
        android:singleLine="true"
        android:hint="Chọn ngày..."
        android:layout_marginTop="@dimen/spacing_sm"
        android:autofillHints="off" />
</LinearLayout>
