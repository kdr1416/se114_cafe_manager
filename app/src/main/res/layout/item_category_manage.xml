<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="@dimen/spacing_lg"
    android:layout_marginBottom="@dimen/spacing_sm">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Cafe.Subtitle"
                android:textStyle="bold"
                tools:text="Cà phê" />

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Cafe.Caption"
                android:textColor="@color/text_soft"
                android:layout_marginTop="2dp"
                tools:text="Các loại nước uống từ hạt cà phê hạt rang xay nguyên chất" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="@dimen/spacing_sm">

        <TextView
            android:id="@+id/btn_edit"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/height_button_sm"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_md"
            android:textAppearance="@style/TextAppearance.Cafe.Caption"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:text="Sửa" />

        <TextView
            android:id="@+id/btn_delete"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/height_button_sm"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_md"
            android:textAppearance="@style/TextAppearance.Cafe.Caption"
            android:textStyle="bold"
            android:textColor="@color/error"
            android:text="Xoá" />
    </LinearLayout>
</LinearLayout>
