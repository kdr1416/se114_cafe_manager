<?xml version="1.0" encoding="utf-8"?>
<!--
    Reusable top bar.
    - btn_back (ImageButton): mặc định visible. Set GONE qua code nếu là entry screen.
    - tv_title (TextView): set qua code hoặc tools:text trong layout cha.
    - tv_caption (TextView): set qua code, set GONE nếu không có.
    - btn_right (ImageButton): mặc định GONE. Set src + visible qua code (search/add/...).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="@dimen/spacing_md"
    android:background="@color/bg_primary">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="@dimen/height_icon_button"
        android:layout_height="@dimen/height_icon_button"
        android:src="@drawable/ic_arrow_back"
        android:background="@drawable/bg_icon_button"
        android:scaleType="centerInside"
        android:layout_marginEnd="@dimen/spacing_xs" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginHorizontal="@dimen/spacing_md">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:singleLine="true"
            android:textAppearance="@style/TextAppearance.Cafe.Title" />

        <TextView
            android:id="@+id/tv_caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Cafe.Caption"
            android:layout_marginTop="@dimen/spacing_xs" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/container_btn_right_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btn_right_2"
            android:layout_width="@dimen/height_icon_button"
            android:layout_height="@dimen/height_icon_button"
            android:background="@drawable/bg_icon_button"
            android:scaleType="centerInside"
            android:contentDescription="Action 2" />

        <TextView
            android:id="@+id/badge_right_2"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/bg_badge_notification"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_gravity="end|top"
            android:layout_marginEnd="4dp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />
    </FrameLayout>

    <ImageButton
        android:id="@+id/btn_right"
        android:layout_width="@dimen/height_icon_button"
        android:layout_height="@dimen/height_icon_button"
        android:src="@drawable/ic_search"
        android:background="@drawable/bg_icon_button"
        android:scaleType="centerInside"
        android:visibility="gone"
        android:contentDescription="@string/content_desc_search"
        android:layout_marginStart="@dimen/spacing_xs" />
</LinearLayout>
