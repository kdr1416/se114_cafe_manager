<?xml version="1.0" encoding="utf-8"?>
<!--
    Reusable top bar.
    - btn_back (ImageButton): mặc định visible. Set GONE qua code nếu là entry screen.
    - tv_title (TextView): set qua code hoặc tools:text trong layout cha.
    - tv_caption (TextView): set qua code, set GONE nếu không có.
    - btn_right (ImageButton): mặc định GONE. Set src + visible qua code (search/add/...).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="@dimen/spacing_lg"
    android:background="@color/bg_primary">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="@dimen/height_icon_button"
        android:layout_height="@dimen/height_icon_button"
        android:src="@drawable/ic_arrow_back"
        android:background="@drawable/bg_icon_button"
        android:scaleType="centerInside"
        android:contentDescription="@string/content_desc_back" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginHorizontal="@dimen/spacing_md">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Cafe.Title"
            tools:text="Tiêu đề"
            xmlns:tools="http://schemas.android.com/tools" />

        <TextView
            android:id="@+id/tv_caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Cafe.Caption"
            android:layout_marginTop="@dimen/spacing_xs"
            tools:text="Mô tả ngắn"
            xmlns:tools="http://schemas.android.com/tools" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_right"
        android:layout_width="@dimen/height_icon_button"
        android:layout_height="@dimen/height_icon_button"
        android:src="@drawable/ic_search"
        android:background="@drawable/bg_icon_button"
        android:scaleType="centerInside"
        android:visibility="gone"
        android:contentDescription="@string/content_desc_search" />
</LinearLayout>
