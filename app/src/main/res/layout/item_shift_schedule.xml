<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="@dimen/spacing_lg"
    android:layout_marginBottom="@dimen/spacing_md">

    <!-- Row 1: name + status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_shift_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/TextAppearance.Cafe.Subtitle" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm"
            android:paddingTop="@dimen/spacing_xs"
            android:paddingBottom="@dimen/spacing_xs"
            style="@style/TextAppearance.Cafe.Caption" />
    </LinearLayout>

    <!-- Row 2: time + staff count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/spacing_xs">

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/TextAppearance.Cafe.Caption" />

        <TextView
            android:id="@+id/tv_staff_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Cafe.Caption" />
    </LinearLayout>

    <!-- Action button -->
    <Button
        android:id="@+id/btn_action"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/height_button_sm"
        style="@style/Widget.Cafe.Button.Secondary"
        android:text="Hành động ▼"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_gravity="end" />
</LinearLayout>
