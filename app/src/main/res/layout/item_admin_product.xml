<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card"
    android:padding="@dimen/spacing_lg"
    android:layout_marginBottom="@dimen/spacing_md">

    <!-- iv_thumb: Bổ sung theo yêu cầu instruction 3 -->
    <ImageView
        android:id="@+id/iv_thumb"
        android:layout_width="@dimen/thumb_size"
        android:layout_height="@dimen/thumb_size"
        android:src="@drawable/ic_coffee"
        android:background="@drawable/bg_media"
        android:padding="@dimen/spacing_md"
        android:contentDescription="@null"
        app:tint="@color/accent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/spacing_md">

        <TextView
            android:id="@+id/tv_product_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Cafe.BodyBold"
            tools:text="Cà phê sữa" />

        <TextView
            android:id="@+id/tv_product_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Cafe.Caption"
            android:layout_marginTop="2dp"
            tools:text="Cà phê · 35.000đ" />

        <TextView
            android:id="@+id/tv_status_badge"
            style="@style/Widget.Cafe.Badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            tools:text="Đang hiển thị"
            tools:background="@drawable/bg_badge_success" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/btn_toggle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_eye"
            android:background="@drawable/bg_icon_button"
            android:scaleType="centerInside"
            android:contentDescription="@string/content_desc_toggle_visibility" />

        <ImageButton
            android:id="@+id/btn_edit"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_edit"
            android:background="@drawable/bg_icon_button"
            android:scaleType="centerInside"
            android:contentDescription="@string/content_desc_edit"
            android:layout_marginTop="@dimen/spacing_sm" />
    </LinearLayout>
</LinearLayout>
