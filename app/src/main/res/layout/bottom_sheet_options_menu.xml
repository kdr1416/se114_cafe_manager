<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingHorizontal="@dimen/spacing_lg"
    android:paddingTop="@dimen/spacing_md"
    android:paddingBottom="@dimen/spacing_xl">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="@color/text_soft"
        android:alpha="0.3"
        android:layout_marginBottom="@dimen/spacing_md" />

    <!-- ===== Section: TÔI ===== -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TÔI"
        android:textAppearance="@style/TextAppearance.Cafe.Caption"
        android:textColor="@color/text_soft"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginBottom="@dimen/spacing_xs" />

    <LinearLayout
        android:id="@+id/row_profile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_eye"
            android:contentDescription="Hồ sơ cá nhân" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hồ sơ cá nhân"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_my_shift"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_check"
            android:contentDescription="Ca làm của tôi" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ca làm của tôi"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_my_availability"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_check"
            android:contentDescription="Lịch rảnh của tôi" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lịch rảnh của tôi"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_leave_request"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_close"
            android:contentDescription="Đơn xin nghỉ" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đơn xin nghỉ"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_news"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_bell"
            android:contentDescription="Bảng tin chung" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bảng tin chung"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_chat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_chat"
            android:contentDescription="Chat nội bộ" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chat nội bộ"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/text_soft"
        android:alpha="0.2"
        android:layout_marginVertical="@dimen/spacing_sm" />

    <!-- ===== Section: QUẢN LÝ ===== -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUẢN LÝ"
        android:textAppearance="@style/TextAppearance.Cafe.Caption"
        android:textColor="@color/text_soft"
        android:layout_marginBottom="@dimen/spacing_xs" />

    <LinearLayout
        android:id="@+id/row_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_receipt"
            android:contentDescription="Lịch sử giao dịch" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lịch sử giao dịch"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_dashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_dashboard"
            android:contentDescription="Báo cáo doanh thu" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Báo cáo doanh thu"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_users"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_eye"
            android:contentDescription="Quản lý nhân viên" />

        <TextView
            android:id="@+id/tv_row_users_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quản lý nhân viên"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_attendance_report"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_check"
            android:contentDescription="Quản lý chấm công" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quản lý chấm công"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_tables"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_table"
            android:contentDescription="Quản lý bàn" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quản lý bàn"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_promotions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_plus"
            android:contentDescription="Quản lý khuyến mãi" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quản lý khuyến mãi"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_categories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_menu_book"
            android:contentDescription="Quản lý danh mục" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quản lý danh mục"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/text_soft"
        android:alpha="0.2"
        android:layout_marginVertical="@dimen/spacing_sm" />

    <!-- ===== Section: CA LÀM VIỆC ===== -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CA LÀM VIỆC"
        android:textAppearance="@style/TextAppearance.Cafe.Caption"
        android:textColor="@color/text_soft"
        android:layout_marginBottom="@dimen/spacing_xs" />

    <LinearLayout
        android:id="@+id/row_leave_approval"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_check"
            android:contentDescription="Duyệt đơn xin nghỉ" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Duyệt đơn xin nghỉ"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_shift_report"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_dashboard"
            android:contentDescription="Xem báo cáo ca" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Xem báo cáo ca"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_shift_schedule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_check"
            android:contentDescription="Lịch ca làm việc" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lịch ca làm việc"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_shift_template"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_menu_book"
            android:contentDescription="Quản lý mẫu ca" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quản lý mẫu ca"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/text_soft"
        android:alpha="0.2"
        android:layout_marginVertical="@dimen/spacing_sm" />

    <!-- ===== Bottom: Đăng xuất ===== -->
    <LinearLayout
        android:id="@+id/row_logout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_button"
            android:padding="@dimen/spacing_xs"
            android:src="@drawable/ic_close"
            android:contentDescription="Đăng xuất"
            app:tint="@color/error"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đăng xuất"
            android:textAppearance="@style/TextAppearance.Cafe.Body"
            android:textColor="@color/error"
            android:layout_marginStart="@dimen/spacing_md" />
    </LinearLayout>
</LinearLayout>
</ScrollView>
