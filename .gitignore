# =========================================================================
# Root-level .gitignore for Cafe Manager Monorepo
# =========================================================================

# --- macOS / Windows / Linux system files ---
.DS_Store
Thumbs.db
*.tmp
*.bak
*.swp

# --- IDE & Editor files ---
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.clinerules
.clineignore
.agents/
.codex/
.trellis/

# --- Backend (Spring Boot / Maven) ---
backend/target/
backend/.mvn/
backend/*.log
backend/.env

# --- Web Dashboard (React / Vite / Node) ---
cafe-dashboard/node_modules/
cafe-dashboard/dist/
cafe-dashboard/.env
cafe-dashboard/.env.local
cafe-dashboard/.env.*.local

# --- Frontend Mobile (Android) ---
frontend/.gradle/
frontend/build/
frontend/local.properties
frontend/.idea/
frontend/app/build/
frontend/capture/
frontend/scheduling_debug.txt
frontend/.clinerules
frontend/.agents/
frontend/.claude/
frontend/.codex/
frontend/.trellis/
frontend/app.jsx.artifact.json
