# Database Connection Configuration (Supabase PostgreSQL)
SUPABASE_URL=jdbc:postgresql://<your-supabase-db-host>:<port>/postgres
SUPABASE_PASSWORD=<your-database-password>
SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Email Service Configuration (Gmail SMTP for OTP login)
SPRING_MAIL_USERNAME=<your-gmail-address>
SPRING_MAIL_PASSWORD=<your-gmail-app-password>
